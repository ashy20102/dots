{

   "niri/workspaces": {
        "all-outputs": true
    },

    "clock": {
	    "interval": 1,
		"format": "{:%d/%m/%Y - %H:%M:%S}"
	},

	"backlight": {
	    "format": "{icon} {percent}%",
		"format-icons": [
			"ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"
		],
	},

	"pulseaudio": {
		"format": "{icon} {volume}%",
        "format-muted": "ΎΣο Muted",
        "format-icons": {
			"headset": "≤░ΜΜ",
			"headphone": "≤░ΜΜ",
			"default": [
				"≤░Χ┐",
				"≤░ΨΑ",
				"≤░Χ╛"
			]
		},
        "on-click": "pavucontrol"
	},

	"pulseaudio#mic": {
        "format": "{format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒ Muted",
        "on-click": "pactl set-source-mute 0 toggle",
        "on-scroll-down": "pactl set-source-volume 0 -1%",
        "on-scroll-up": "pactl set-source-volume 0 +1%",
        "scroll-step": 5
    },

	"niri/language": {
        "format": "≤░ΝΝ {}"
	},

	"power-profiles-daemon": {
	    "format": "{icon}",
	    "tooltip-text": "Power profile: {profile}\nDriver: {driver}",
	    "tooltip": true,
	    "format-icons": {
	        "default": "≤░╛Ζ Balanced",
	        "performance": "≤░ΥΖ Performance",
	        "balanced": "≤░╛Ζ Balanced",
	        "power-saver": "≤░╛Η Power save"
	    }
	},

	"battery": {
        "interval": 2,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} (Full)%",
        "format-charging": "ΎΘο {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        // "format-alt": "{icon} {time}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "on-click": "alacritty -e bathis"
	},

	"memory": {
	   "interval": 2,
	   "format": "Ό┐Ζ {used:0.1f}GB / {total:0.1f}GB"
	},

	"cpu": {
	   "interval": 2,
	   "format": "Ό░β {usage}%"
	},

        "tray": {
            "max-icon-size": 16,
            "icons": true,
            "wmname": "LG3D"
        },

	"custom/power": {
        "format": " ΎΑΣ ",
        "on-click": "kitty -e sh ~/.config/waybar/stuff/scripts/power.sh"
    },
}
